<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::system">
                    <resource id="DotCommerce_CronScheduler::scheduler" title="Cron Scheduler" sortOrder="110">
                        <resource id="DotCommerce_CronScheduler::jobs" title="Cron Jobs List" sortOrder="10"/>
                        <resource id="DotCommerce_CronScheduler::tasks" title="Cron Tasks List" sortOrder="20"/>
                        <resource id="DotCommerce_CronScheduler::config" title="Configuration" sortOrder="30"/>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>