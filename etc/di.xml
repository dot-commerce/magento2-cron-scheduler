<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="DotCommerce\CronScheduler\Api\Data\JobInterface"
                type="DotCommerce\CronScheduler\Model\Job"/>
    <preference for="DotCommerce\CronScheduler\Api\Data\JobSearchResultsInterface"
                type="Magento\Framework\Api\SearchResults"/>
    <preference for="DotCommerce\CronScheduler\Api\JobRepositoryInterface"
                type="DotCommerce\CronScheduler\Model\JobRepository"/>

    <type name="Magento\Cron\Model\Config">
        <plugin name="dc_cronscheduler_apply_overrides"
                type="DotCommerce\CronScheduler\Plugin\Cron\ApplyJobOverrides"/>
    </type>
</config>
