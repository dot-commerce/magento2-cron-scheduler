<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">dc_cronscheduler_tasks_listing.dc_cronscheduler_tasks_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>dc_cronscheduler_tasks_listing_columns</spinner>
        <deps>
            <dep>dc_cronscheduler_tasks_listing.dc_cronscheduler_tasks_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="dc_cronscheduler_tasks_listing_data_source"
                component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">schedule_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>DotCommerce_CronScheduler::tasks</aclResource>
        <dataProvider name="dc_cronscheduler_tasks_listing_data_source"
                      class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
            <settings>
                <requestFieldName>schedule_id</requestFieldName>
                <primaryFieldName>schedule_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters">
            <filterSelect name="status" provider="${ $.parentName }">
                <settings>
                    <options class="DotCommerce\CronScheduler\Model\Source\ScheduleStatusOptions"/>
                    <caption translate="true">Select Status...</caption>
                    <label translate="true">Status</label>
                    <dataScope>status</dataScope>
                </settings>
            </filterSelect>
        </filters>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected cron task records?</message>
                        <title translate="true">Delete Records</title>
                    </confirm>
                    <url path="dc_cronscheduler/tasks/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="dc_cronscheduler_tasks_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>schedule_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="schedule_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        <column name="job_code">
            <settings>
                <filter>text</filter>
                <label translate="true">Job Code</label>
            </settings>
        </column>
        <column name="status" component="Magento_Ui/js/grid/columns/select"
                class="DotCommerce\CronScheduler\Ui\Component\Listing\Column\ScheduleStatus">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">DotCommerce\CronScheduler\Model\Source\ScheduleStatusOptions</item>
                <item name="config" xsi:type="array">
                    <item name="bodyTmpl" xsi:type="string">ui/grid/cells/html</item>
                </item>
            </argument>
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="messages">
            <settings>
                <filter>text</filter>
                <label translate="true">Messages</label>
            </settings>
        </column>
        <column name="created_at" component="Magento_Ui/js/grid/columns/date" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <column name="scheduled_at" component="Magento_Ui/js/grid/columns/date" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Scheduled At</label>
            </settings>
        </column>
        <column name="executed_at" component="Magento_Ui/js/grid/columns/date" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Executed At</label>
            </settings>
        </column>
        <column name="finished_at" component="Magento_Ui/js/grid/columns/date" class="Magento\Ui\Component\Listing\Columns\Date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Finished At</label>
            </settings>
        </column>
    </columns>
</listing>
